<table role="presentation" border="0" cellpadding="0" cellspacing="0">
    <tbody>
        <tr>
            <td>Nom</td>
            <td>{{ contact.lastname }}</td>
        </tr>
        <tr>
            <td>Prénom</td>
            <td>{{ contact.firstname }}</td>
        </tr>
        <tr>
            <td>Object</td>
            <td>{{ contact.object }}</td>
        </tr>
        <tr>
            <td>Email</td>
            <td>{{ contact.email }}</td>
        </tr>
        <tr>
            <td>Téléphone</td>
            <td>{{ contact.phone }}</td>
        </tr>
        <tr>
            <td>Message</td>
            <td>{{ contact.message }}</td>
        </tr>
    </tbody>
</table>