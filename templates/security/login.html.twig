{% extends 'login.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}

<style>

body {
    background: #7b95a2;
}

</style>

<div class="container">
    <div class="row">
        <div class="col-md-6 card my-5 p-3" style="margin:auto">
            <form method="post">
                {% if error %}
                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                {% if app.user %}
                    <div class="mb-3">
                        You are logged in as {{ app.user.username }}, <a href="{{ path('app_logout') }}">Logout</a>
                    </div>
                {% endif %}
                <h1 class="h4 text-gray-900 mb-4 text-center">Bienvenue</h1>
                <h1 class="h3 mb-3 font-weight-normal">Please sign in</h1>
                <div class="from-group">
                    <input type="email" value="{{ last_username }}" name="email" placeholder="Adresse Email" id="inputEmail" class="form-control" required autofocus>
                </div>
                <div class="form-group">
                    <input type="password" name="password" placeholder="Mot de passe" id="inputPassword" class="form-control" required>
                </div>

                <input type="hidden" name="_csrf_token"
                    value="{{ csrf_token('authenticate') }}"
                >

                {#
                    Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
                    See https://symfony.com/doc/current/security/remember_me.html

                    <div class="checkbox mb-3">
                        <label>
                            <input type="checkbox" name="_remember_me"> Remember me
                        </label>
                    </div>
                #}

                <button class="btn btn-lg btn-danger" type="submit">
                    Connexion
                </button>
            </form>
        </div>
    </div>
</div>

{% endblock %}
